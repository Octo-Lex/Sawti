# Sawti environment configuration template.
# Copy to `.env` and fill in real values. Never commit the real `.env`.

# GitHub access (used by tooling/CI, not the runtime app).
# Create at https://github.com/settings/tokens with the minimum scope needed.
GH_TOKEN=ghp_your_token_here

# Hugging Face access (needed in M1 for gated models such as SeamlessM4T).
# Create at https://huggingface.co/settings/tokens.
HF_TOKEN=hf_your_token_here
